# Custom overrides. Keep these before the base domestic/foreign + ad rules.
# US-only broker services.
DOMAIN-KEYWORD,interactivebrokers,US
DOMAIN-SUFFIX,interactivebrokers.com,US
DOMAIN-SUFFIX,ibkr.com,US
DOMAIN-KEYWORD,thinkorswim,US
DOMAIN-SUFFIX,thinkorswim.com,US
DOMAIN-SUFFIX,schwab.com,US
DOMAIN-SUFFIX,schwabapi.com,US
DOMAIN-SUFFIX,robinhood.com,US
DOMAIN-SUFFIX,fidelity.com,US

# Gemini and its supporting Google AI endpoints require a US IP.
DOMAIN-SUFFIX,gemini.google.com,US
DOMAIN-SUFFIX,aistudio.google.com,US
DOMAIN-SUFFIX,ai.google.dev,US
DOMAIN-SUFFIX,generativelanguage.googleapis.com,US

# Tonghuashun uses the local network directly.
DOMAIN-KEYWORD,10jqka,DIRECT
DOMAIN-SUFFIX,10jqka.com.cn,DIRECT
DOMAIN-SUFFIX,10jqka.com,DIRECT
